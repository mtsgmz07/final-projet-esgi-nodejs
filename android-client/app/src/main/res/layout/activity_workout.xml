<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Séance en cours"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvExerciseName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Exercice : Squat"
        android:textSize="22sp"
        android:layout_marginTop="30dp" />

    <TextView
        android:id="@+id/tvExerciseInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Série : 1/3 - Objectif : 12 répétitions"
        android:textSize="16sp"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/tvTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textSize="40sp"
        android:textStyle="bold"
        android:layout_marginTop="30dp" />

    <Button
        android:id="@+id/btnStartTimer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Démarrer"
        android:layout_marginTop="20dp" />

    <Button
        android:id="@+id/btnNextExercise"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Exercice suivant" />

    <EditText
        android:id="@+id/etPerformance"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Performance réalisée"
        android:layout_marginTop="20dp" />

</LinearLayout>